{
    "rewrites": [
        {
            "source": "/api/cron/update_session",
            "destination": "/api/cron/update_session"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/update_session",
            "schedule": "* * * * *"
        }
    ]
}